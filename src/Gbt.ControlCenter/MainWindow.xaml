<Window x:Class="Gbt.ControlCenter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AORUS Control Center (Open)" Height="780" Width="500"
        Background="#FF15151A" Foreground="#FFEAEAEA" FontFamily="Segoe UI">
    <Window.Resources>
        <SolidColorBrush x:Key="Accent" Color="#FFEF6C00"/>
        <SolidColorBrush x:Key="CardBg" Color="#FF24242B"/>
        <SolidColorBrush x:Key="TrackBg" Color="#FF2A2A31"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFEAEAEA"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF9A9AA5"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBg}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Background" Value="#FF2D2D34"/>
            <Setter Property="Foreground" Value="#FFEAEAEA"/>
            <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="#FFEAEAEA"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Draggable fan-curve point -->
        <Style x:Key="PointThumb" TargetType="Thumb">
            <Setter Property="Width" Value="14"/>
            <Setter Property="Height" Value="14"/>
            <Setter Property="Cursor" Value="SizeAll"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Ellipse Fill="{StaticResource Accent}" Stroke="White" StrokeThickness="1.5"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="18">

            <!-- Header -->
            <DockPanel Margin="0,0,0,14">
                <Ellipse Width="10" Height="10" Fill="#FF4CAF50" DockPanel.Dock="Right" VerticalAlignment="Top" Margin="0,6,0,0"/>
                <StackPanel>
                    <TextBlock Text="{Binding ModelName}" FontSize="20" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding CurrentMode, StringFormat='Active mode: {0}'}" Style="{StaticResource Label}"/>
                </StackPanel>
            </DockPanel>

            <!-- Performance modes -->
            <UniformGrid Columns="4" Margin="0,0,0,12">
                <Button Content="Quiet" Command="{Binding SetQuietCommand}"/>
                <Button Content="Normal" Command="{Binding SetNormalCommand}"/>
                <Button Content="Gaming" Command="{Binding SetGamingCommand}"/>
                <Button Content="Boost" Command="{Binding SetBoostCommand}"/>
            </UniformGrid>

            <!-- Sensor cards -->
            <UniformGrid Columns="2" Margin="0,0,0,12">
                <Border Style="{StaticResource Card}" Margin="0,0,6,0">
                    <StackPanel>
                        <TextBlock Text="CPU" Style="{StaticResource Label}"/>
                        <TextBlock Text="{Binding CpuTemp}" FontSize="26" FontWeight="SemiBold"/>
                        <ProgressBar Height="6" Maximum="100" Value="{Binding CpuTempValue}" Margin="0,6"
                                     Foreground="{StaticResource Accent}" Background="{StaticResource TrackBg}" BorderThickness="0"/>
                        <TextBlock Text="{Binding CpuFan}" Style="{StaticResource Label}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Margin="6,0,0,0">
                    <StackPanel>
                        <TextBlock Text="GPU" Style="{StaticResource Label}"/>
                        <TextBlock Text="{Binding GpuTemp}" FontSize="26" FontWeight="SemiBold"/>
                        <ProgressBar Height="6" Maximum="100" Value="{Binding GpuTempValue}" Margin="0,6"
                                     Foreground="{StaticResource Accent}" Background="{StaticResource TrackBg}" BorderThickness="0"/>
                        <TextBlock Text="{Binding GpuFan}" Style="{StaticResource Label}"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Power -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                <DockPanel>
                    <TextBlock Text="Power limits" Style="{StaticResource Label}"/>
                    <TextBlock Text="{Binding PowerLimits}" HorizontalAlignment="Right"/>
                </DockPanel>
            </Border>

            <!-- Fan curve editor -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                <StackPanel>
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Text="Fan curve" Style="{StaticResource Label}"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <RadioButton x:Name="CpuRadio" Content="CPU" IsChecked="True" Margin="0,0,10,0"
                                         GroupName="curve" Checked="OnCurveTargetChanged"/>
                            <RadioButton x:Name="GpuRadio" Content="GPU" GroupName="curve" Checked="OnCurveTargetChanged"/>
                        </StackPanel>
                    </DockPanel>
                    <Border Background="#FF101015" CornerRadius="6" Height="200">
                        <Canvas x:Name="CurveCanvas" ClipToBounds="True" Background="Transparent"
                                SizeChanged="OnCurveCanvasSizeChanged"/>
                    </Border>
                    <TextBlock Text="Drag the points to shape the curve, then Apply." Style="{StaticResource Label}"
                               FontSize="11" Margin="0,6,0,0"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
                        <Button Content="Reset" Click="OnResetCurve"/>
                        <Button Content="Apply curve" Click="OnApplyCurve"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Battery -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="{Binding Battery, StringFormat='Battery: {0}'}" Margin="0,0,0,8"/>
                    <TextBlock Text="Charge limit" Style="{StaticResource Label}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Slider Grid.Column="0" Minimum="50" Maximum="100" TickFrequency="5" IsSnapToTickEnabled="True"
                                Value="{Binding BatteryLimit, Mode=TwoWay}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding BatteryLimit, StringFormat='{}{0:F0}%'}" Margin="10,0" MinWidth="40"/>
                        <Button Grid.Column="2" Content="Apply" Command="{Binding ApplyBatteryCommand}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <TextBlock Text="{Binding Status}" Style="{StaticResource Label}" TextWrapping="Wrap"/>
        </StackPanel>
    </ScrollViewer>
</Window>
